generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChallengeStatus {
  OPEN
  REVIEW
  ARCHIVED
}

enum ChallengeSource {
  GITHUB
  MOCK
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum ChallengeEngagementStatus {
  SAVED
  STARTED
  COMPLETED
}

enum ChallengeCompletionMethod {
  MANUAL
  AUTOMATED
}

enum ChallengeSyncRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

model User {
  id                   String               @id @default(cuid())
  name                 String
  email                String               @unique
  githubUsername       String               @unique
  bio                  String?
  avatarInitials       String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  submissions          Submission[]
  score                Score?
  challengeEngagements ChallengeEngagement[]
  challengeSyncRuns    ChallengeSyncRun[]
}

model Repository {
  id               String      @id @default(cuid())
  githubRepositoryId Int?      @unique
  owner            String
  name             String
  fullName         String      @unique
  description      String?
  language         String?
  stars            Int         @default(0)
  openIssues       Int         @default(0)
  url              String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  challenges       Challenge[]
}

model Challenge {
  id                 String          @id @default(cuid())
  githubNodeId       String?         @unique
  githubIssueId      Int?            @unique
  slug               String          @unique
  title              String
  summary            String
  body               String
  difficulty         String
  status             ChallengeStatus @default(OPEN)
  source             ChallengeSource @default(MOCK)
  sourceCreatedAt    DateTime?
  sourceUpdatedAt    DateTime?
  lastSyncedAt       DateTime?
  inactiveReason     String?
  labels             String[]
  techStack          String[]
  issueNumber        Int
  issueUrl           String
  estimatedMinutes   Int
  points             Int             @default(0)
  acceptanceCriteria String[]
  workflowSteps      String[]
  learningOutcomes   String[]
  repositoryId       String
  repository         Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  submissions        Submission[]
  engagements        ChallengeEngagement[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([repositoryId, issueNumber])
  @@index([source, status])
  @@index([source, lastSyncedAt])
}

model Submission {
  id          String           @id @default(cuid())
  title       String
  summary     String
  checklist   String[]
  status      SubmissionStatus @default(DRAFT)
  challengeId String
  challenge   Challenge        @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Score {
  id                  String   @id @default(cuid())
  totalPoints         Int      @default(0)
  currentStreak       Int      @default(0)
  completedChallenges Int      @default(0)
  rankLabel           String
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt           DateTime @updatedAt

  @@index([totalPoints, completedChallenges])
}

model ChallengeEngagement {
  id               String                   @id @default(cuid())
  status           ChallengeEngagementStatus @default(SAVED)
  completionMethod ChallengeCompletionMethod?
  pointsAwarded    Int                      @default(0)
  savedAt          DateTime                 @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  challengeId      String
  challenge        Challenge                @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId           String
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId, status])
  @@index([challengeId])
  @@index([status, completedAt])
}

model ChallengeSyncRun {
  id                String                 @id @default(cuid())
  source            String                 @default("github")
  status            ChallengeSyncRunStatus @default(RUNNING)
  fetchedCount      Int                    @default(0)
  importedCount     Int                    @default(0)
  updatedCount      Int                    @default(0)
  skippedCount      Int                    @default(0)
  archivedCount     Int                    @default(0)
  activeCount       Int                    @default(0)
  message           String?
  logs              String[]               @default([])
  startedAt         DateTime               @default(now())
  completedAt       DateTime?
  triggeredByUserId String?
  triggeredByUser   User?                  @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([status, startedAt])
  @@index([startedAt])
}
